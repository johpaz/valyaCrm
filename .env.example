# Variables de entorno para el agente WhatsApp-Gemini/Kimi
# Copia este archivo como .env y configura los valores reales

# ==============================================
# CONFIGURACIÓN DE MOTOR DE IA
# ==============================================



# ==============================================
# CONFIGURACIÓN DE GOOGLE GEMINI
# ==============================================
# Obtén tu API key en: https://aistudio.google.com/
GEMINI_API_KEY=tu_api_key_de_gemini_aqui


# ==============================================
# CONFIGURACIÓN DE WHATSAPP BUSINESS API
# ==============================================
# Configura tu aplicación en: https://developers.facebook.com/
WHATSAPP_ACCESS_TOKEN=tu_access_token_de_whatsapp_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu_webhook_verify_token_aqui

# ==============================================
# CONFIGURACIÓN DE OPENAI (OPCIONAL)
# ==============================================
# API Key de OpenAI para transcripción de audio con Whisper
# Obtén tu API key en: https://platform.openai.com/api-keys
# Si no se configura, se usará transcripción simulada
OPENAI_API_KEY=tu_api_key_de_openai_aqui

# ==============================================
# CONFIGURACIÓN DE MONGODB
# ==============================================
# URI de conexión a MongoDB (local o en la nube)
# Ejemplos:
# Local: mongodb://localhost:27017/whatsapp_agent_db
# MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/whatsapp_agent_db
MONGODB_URI=mongodb://localhost:27017/whatsapp_agent_db

# ==============================================
# CONFIGURACIÓN DEL SERVIDOR
# ==============================================
PORT=3000
NODE_ENV=development

# ==============================================
# CONFIGURACIÓN DE LOGGING
# ==============================================
# Niveles disponibles: error, warn, info, debug
LOG_LEVEL=info

# ==============================================
# CONFIGURACIÓN OPCIONAL
# ==============================================
# Límites de rate limiting (mensajes por minuto/hora)
# MAX_MESSAGES_PER_MINUTE=30
# MAX_MESSAGES_PER_HOUR=100

# TTL del cache en segundos
# CACHE_TTL=300

# Configuración de archivos multimedia
# Tiempo en horas para limpiar archivos multimedia antiguos
MEDIA_CLEANUP_HOURS=24

# Webhooks adicionales para notificaciones
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ==============================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ==============================================
# 1. Copia este archivo como .env
# 2. Reemplaza todos los valores "tu_*_aqui" con tus credenciales reales
# 3. Configura la URI de MongoDB (local o en la nube)
# 4. Guarda el archivo y reinicia el servidor
# 5. Verifica que el servidor inicie sin errores

# IMPORTANTE: Nunca subas el archivo .env a un repositorio público

# ==============================================
# CONFIGURACIÓN DE LANGCHAIN (NUEVO)
# ==============================================
# Habilitar el uso del sistema de agentes con Langchain
USE_LANGCHAIN=true

# ==============================================
# CONFIGURACIÓN DE MONGODB ATLAS (EJEMPLO)
# ==============================================
# Si usas MongoDB Atlas (recomendado para producción):
# 1. Crea un cluster en https://cloud.mongodb.com/
# 2. Crea un usuario de base de datos
# 3. Configura las IPs permitidas (0.0.0.0/0 para desarrollo)
# 4. Obtén la URI de conexión y reemplaza:
# MONGODB_URI=mongodb+srv://tu_usuario:tu_password@tu_cluster.mongodb.net/whatsapp_agent_db?retryWrites=true&w=majority

